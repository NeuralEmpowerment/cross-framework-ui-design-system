@layer components {
  .{{componentNameKebab}} {
    {{#if_eq type "display"}}
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: var(--ds-space-2) var(--ds-space-4);
    border-radius: var(--ds-radius-md);
    border: 1px solid var(--ds-color-border);
    background: var(--ds-color-surface);
    color: var(--ds-color-fg);
    box-shadow: var(--ds-shadow-sm);
    {{/if_eq}}
    {{#if_eq type "form"}}
    display: block;
    width: 100%;
    padding: var(--ds-space-2) var(--ds-space-3);
    border-radius: var(--ds-radius-md);
    border: 1px solid var(--ds-color-border);
    background: var(--ds-color-surface);
    color: var(--ds-color-fg);
    font-family: inherit;
    font-size: var(--ds-text-md);
    line-height: 1.5;
    transition: border-color var(--ds-duration-base) var(--ds-ease), box-shadow var(--ds-duration-base) var(--ds-ease);
    {{/if_eq}}
    {{#if_eq type "layout"}}
    display: block;
    background: var(--ds-color-surface);
    border: 1px solid var(--ds-color-border);
    border-radius: var(--ds-radius-md);
    {{/if_eq}}
    {{#if_eq type "utility"}}
    position: relative;
    background: var(--ds-color-surface);
    border: 1px solid var(--ds-color-border);
    border-radius: var(--ds-radius-md);
    box-shadow: var(--ds-shadow-md);
    {{/if_eq}}
  }

  {{#if_eq type "form"}}
  .{{componentNameKebab}}:focus {
    outline: none;
    border-color: var(--ds-color-accent);
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--ds-color-accent), transparent 80%);
  }

  .{{componentNameKebab}}:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    background: var(--ds-color-overlay);
  }

  .{{componentNameKebab}}::placeholder {
    color: var(--ds-color-text-muted);
  }
  {{/if_eq}}

  {{#if_eq type "display"}}
  .{{componentNameKebab}}:hover {
    box-shadow: var(--ds-shadow-md);
  }

  .{{componentNameKebab}}:active {
    transform: translateY(1px);
  }
  {{/if_eq}}

  {{#if hasVariants}}
  {{#each variants}}
  {{#each values}}
  .{{../../componentNameKebab}}--{{this}} {
    {{#if_eq this "primary"}}
    background: var(--ds-color-accent);
    border-color: var(--ds-color-accent);
    color: var(--ds-color-accent-contrast);
    {{/if_eq}}
    {{#if_eq this "secondary"}}
    background: var(--ds-color-surface);
    border-color: var(--ds-color-border);
    color: var(--ds-color-fg);
    {{/if_eq}}
    {{#if_eq this "ghost"}}
    background: transparent;
    border-color: transparent;
    color: var(--ds-color-fg);
    {{/if_eq}}
    {{#if_eq this "danger"}}
    background: var(--ds-color-accent);
    color: var(--ds-color-accent-contrast);
    border-color: var(--ds-color-accent);
    {{/if_eq}}
    {{#if_eq this "success"}}
    background: var(--ds-color-accent);
    color: var(--ds-color-accent-contrast);
    border-color: var(--ds-color-accent);
    {{/if_eq}}
    {{#if_eq this "warning"}}
    background: var(--ds-color-accent);
    color: var(--ds-color-accent-contrast);
    border-color: var(--ds-color-accent);
    {{/if_eq}}
    {{#if_eq this "disabled"}}
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
    {{/if_eq}}
    {{#if_eq this "error"}}
    border-color: var(--ds-color-accent);
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--ds-color-accent), transparent 80%);
    {{/if_eq}}
  }

  {{/each}}
  {{/each}}
  {{/if}}

  {{#each sizes}}
  .{{../componentNameKebab}}--{{this}} {
    {{#if_eq this "xs"}}
    padding: var(--ds-space-1) var(--ds-space-2);
    font-size: var(--ds-text-xs);
    {{/if_eq}}
    {{#if_eq this "sm"}}
    padding: var(--ds-space-1) var(--ds-space-3);
    font-size: var(--ds-text-sm);
    {{/if_eq}}
    {{#if_eq this "md"}}
    padding: var(--ds-space-2) var(--ds-space-4);
    font-size: var(--ds-text-md);
    {{/if_eq}}
    {{#if_eq this "lg"}}
    padding: var(--ds-space-3) var(--ds-space-6);
    font-size: var(--ds-text-lg);
    {{/if_eq}}
    {{#if_eq this "xl"}}
    padding: var(--ds-space-4) var(--ds-space-8);
    font-size: var(--ds-text-xl);
    {{/if_eq}}
  }

  {{/each}}
}
